---
import Layout from '../layouts/Layout.astro';

const verticals = [
  {
    num: '01',
    name: 'Medical Aid',
    reg: 'POPIA S26 · CMS',
    line: 'Member health data is special personal information. Every LLM pilot touches it during inference, not just storage.',
  },
  {
    num: '02',
    name: 'Banking',
    reg: 'SARB Directive 3 · FIC',
    line: 'AML and credit-decision AI sits across POPIA, FIC, and SARB cloud rules at once. The architecture has to satisfy all three.',
  },
  {
    num: '03',
    name: 'Insurance',
    reg: 'SAM · FSCA · TCF',
    line: 'Underwriting and claims AI must be explainable to a regulator and fair to a customer. That is an architecture problem before it is a model problem.',
  },
];

const steps = [
  {
    num: '01',
    title: 'Map the data flow',
    body: 'Classify every point personal information moves through an AI workload: storage, embeddings, prompt history, inference state. Most teams have mapped storage and nothing else.',
  },
  {
    num: '02',
    title: 'Find the regulatory boundary',
    body: 'Mark where POPIA Section 72, Section 26, SARB Directive 3, or SAM obligations are triggered. This is the line your architecture has to defend.',
  },
  {
    num: '03',
    title: 'Design the sovereign path',
    body: 'Choose the deployment that holds: on-prem GPU, Cassava AI Factory, or hybrid retrieval with controlled generation. Documented so legal and the regulator can read it.',
  },
];
---

<Layout
  title="Custos — Sovereign AI architecture for SA regulated industries"
  description="POPIA-compliant AI architecture for South African medical aid, banking, and insurance. Production AI you can defend to your regulator, not just deploy."
>
  <!-- HERO (sovereign AI compute, rooted in Cape Town) -->
  <section class="hero">
    <picture class="hero-img" aria-hidden="true">
      <source srcset="/hero-capetown.webp" type="image/webp" />
      <img src="/hero-capetown.jpg" alt="" width="2200" height="981" fetchpriority="high" />
    </picture>
    <div class="hero-scrim" aria-hidden="true"></div>
    <div class="wrap" style="position: relative; z-index: 2;">
      <p class="hero-eyebrow"><span style="color: var(--accent);">Sovereign AI</span><span class="sep">/</span>South Africa</p>
      <h1 class="hero-h1">Production AI your regulator <span class="serif-em">can't object to.</span></h1>
      <p class="hero-sub">
        South African medical schemes, banks, and insurers are running AI on infrastructure that routes personal data through foreign jurisdictions. Custos designs the architecture that keeps it sovereign, POPIA-compliant, and defensible.
      </p>
      <div class="hero-btns">
        <a href="/services" class="btn-primary" data-magnetic>See the services</a>
        <a href="/approach" class="btn-ghost" data-magnetic>How it works &rarr;</a>
      </div>
    </div>
  </section>

  <!-- residency vs sovereignty diagram (own section, scroll-revealed) -->
  <section class="wrap reveal" style="padding: 1rem 1.5rem 2rem;">
    <div style="border: 1px solid var(--border); border-radius: 12px; background: linear-gradient(180deg, var(--bg-surface), var(--bg)); padding: 2rem 2rem; max-width: 760px; box-shadow: 0 24px 60px -30px rgba(0,0,0,0.8);">
      <p class="card-title" style="margin: 0 0 1.25rem;">The distinction most pilots miss</p>
      <div class="flow-row" style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
        <div class="flow-node">Member data</div>
        <span class="flow-arrow">&rarr;</span>
        <div class="flow-node">Azure ZA-North</div>
        <span class="flow-arrow">&rarr;</span>
        <div class="flow-node boundary">US-controlled provider</div>
      </div>
      <p style="margin: 1.25rem 0 0; font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;">
        Data residency keeps the bytes in SA. It does not put them beyond the reach of foreign law. Sovereignty is who can compel access, not where the disk sits.
      </p>
    </div>
  </section>

  <!-- VERTICALS -->
  <section class="wrap reveal" style="padding: 4rem 1.5rem;">
    <div class="rule">
      <span class="sec-num">[ WHO ]</span>
      <h2 class="label" style="margin: 0;">Three regulated industries</h2>
    </div>
    <div class="grid-3 stagger reveal">
      {verticals.map((v) => (
        <div class="card">
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem;">
            <span class="spec-num">{v.num}</span>
            <span class="chip">{v.reg}</span>
          </div>
          <h3 style="font-size: 1.15rem; font-weight: 700; color: #fff; margin: 0 0 0.65rem; letter-spacing: -0.02em;">{v.name}</h3>
          <p style="margin: 0; font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;">{v.line}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="wrap reveal" style="padding: 4rem 1.5rem;">
    <div class="rule">
      <span class="sec-num">[ HOW ]</span>
      <span class="label">The method</span>
    </div>
    <div class="grid-method">
      <div>
        <h2 class="h-section" style="max-width: 14ch;">Compliance is an architecture decision, not a policy document.</h2>
        <p style="margin: 1.5rem 0 0; font-size: 0.95rem; color: var(--text-muted); line-height: 1.7; max-width: 42ch;">
          Most "AI governance" stops at a written policy. The exposure lives in the data flow: where personal information actually moves when a model runs. Custos works at that layer.
        </p>
      </div>
      <div style="display: flex; flex-direction: column; gap: 0;">
        {steps.map((s, i) => (
          <div style={`display: flex; gap: 1.25rem; padding: 1.5rem 0; ${i > 0 ? 'border-top: 1px solid var(--border);' : ''}`}>
            <span class="spec-num" style="flex-shrink: 0;">{s.num}</span>
            <div>
              <h3 style="font-size: 1rem; font-weight: 600; color: #fff; margin: 0 0 0.4rem;">{s.title}</h3>
              <p style="margin: 0; font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="wrap reveal" style="padding: 4rem 1.5rem 0;">
    <div style="border: 1px solid var(--accent-border); border-radius: 12px; background: linear-gradient(135deg, rgba(59, 130, 246,0.06), transparent 60%), var(--bg-surface); padding: 3rem 2.5rem; text-align: center;">
      <p class="label label-accent" style="margin: 0 0 1rem;">For CIOs, CROs, and Heads of Data</p>
      <h2 class="h-section" style="margin: 0 auto; max-width: 24ch;">"Where does our AI data actually live?" If the answer isn't clean, that's the conversation.</h2>
      <p style="margin: 1.25rem auto 2rem; font-size: 0.95rem; color: var(--text-muted); max-width: 44ch; line-height: 1.65;">
        25 minutes. No pitch. A working session on your AI workloads and where the regulatory exposure sits.
      </p>
      <a href="/contact" class="btn-cta">Start the conversation</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 4rem 0 5rem;
  }
  /* Cape Town hero photo */
  .hero-img {
    position: absolute; inset: 0; z-index: 0;
    display: block;
  }
  .hero-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: 70% center; /* favour the window / Table Mountain side */
    display: block;
  }
  /* Scrim: dark on the left (behind text), clearer on the right (the view) */
  .hero-scrim {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      linear-gradient(90deg, rgba(8,11,18,0.94) 0%, rgba(8,11,18,0.82) 34%, rgba(8,11,18,0.45) 62%, rgba(8,11,18,0.30) 100%),
      linear-gradient(0deg, rgba(8,11,18,0.85) 0%, transparent 40%);
  }
  .hero-eyebrow {
    font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 0.82rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--text-muted); margin: 0 0 1.75rem;
    opacity: 0; transform: translateY(12px); animation: rise .7s .1s ease forwards;
  }
  .hero-eyebrow .sep { color: var(--border); margin: 0 0.55rem; }
  .hero-h1 {
    font-family: var(--heading);
    font-size: clamp(2.3rem, 5.4vw, 3.9rem);
    font-weight: 600; line-height: 1.08; letter-spacing: -0.02em;
    color: #fff; max-width: 17ch; margin: 0;
    overflow-wrap: break-word;
    opacity: 0; transform: translateY(16px); animation: rise .8s .22s cubic-bezier(.2,.7,.2,1) forwards;
  }
  .hero-sub {
    margin: 1.8rem 0 0; font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.6; color: var(--text-muted); max-width: 52ch;
    opacity: 0; transform: translateY(16px); animation: rise .8s .36s ease forwards;
  }
  .hero-btns {
    display: flex; gap: 1rem; margin-top: 2.6rem; flex-wrap: wrap;
    opacity: 0; transform: translateY(16px); animation: rise .8s .5s ease forwards;
  }
  .btn-primary {
    font-family: 'Inter', sans-serif; font-size: 0.95rem;
    background: var(--accent); color: #04122e; padding: 0.85rem 1.6rem;
    border-radius: 8px; font-weight: 600;
    transition: box-shadow .3s, transform .15s, background .2s;
  }
  .btn-primary:hover { box-shadow: 0 10px 34px -8px rgba(59, 130, 246,0.55); transform: translateY(-1px); color: #04122e; background: var(--accent-hover); }
  .btn-ghost {
    font-family: 'Inter', sans-serif; font-size: 0.95rem; font-weight: 600;
    color: #fff; background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    padding: 0.85rem 1.6rem; border-radius: 8px;
    transition: border-color .2s, background .2s, transform .15s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.22); background: rgba(255,255,255,0.10); color: #fff; transform: translateY(-1px); }

  @keyframes rise { to { opacity: 1; transform: translateY(0); } }

  /* scroll reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .7s ease, transform .7s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity: 1; transform: translateY(0); }

  @media (max-width: 820px) {
    /* On phones, push the photo focus to the view and darken more for legibility */
    .hero-img img { object-position: 62% center; }
    .hero-scrim {
      background:
        linear-gradient(180deg, rgba(8,11,18,0.78) 0%, rgba(8,11,18,0.55) 45%, rgba(8,11,18,0.88) 100%);
    }
    .hero { min-height: 78vh; padding: 3rem 0 3.5rem; }
    .hero-h1 { font-size: clamp(1.6rem, 6.8vw, 2.5rem); max-width: 100%; padding-right: 0.5rem; }
    .hero-eyebrow { margin-bottom: 1.25rem; }
    .hero-sub { margin-top: 1.4rem; font-size: 1rem; }
    .hero-btns { margin-top: 2rem; gap: 0.75rem; }
    /* Full-width, tappable CTAs on phones */
    .btn-primary, .btn-ghost {
      flex: 1 1 100%;
      text-align: center;
      padding: 0.95rem 1.4rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-h1, .hero-sub, .hero-btns, .reveal { animation: none !important; opacity: 1 !important; transform: none !important; transition: none !important; }
  }
</style>
