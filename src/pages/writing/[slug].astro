---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const articleMeta = {
  publishedTime: post.data.pubDate?.toISOString(),
  author: 'Tristan de Kock',
  tags: post.data.tags,
};
---

<Layout
  title={`${post.data.title} — Custos`}
  description={post.data.description}
  ogImage={post.data.ogImage ?? '/og-default.png'}
  article={articleMeta}
>
  <article style="max-width: 760px; margin: 0 auto; padding: 4rem 1.5rem;">

    <!-- Back -->
    <a href="/writing" style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--text-muted); display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 3rem;">
      &larr; Writing
    </a>

    <!-- Header -->
    <header style="margin-bottom: 3rem;">
      {post.data.tags && (
        <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem;">
          {post.data.tags.map((tag: string) => (
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--accent); background: var(--accent-dim); border: 1px solid var(--accent-border-soft); border-radius: 3px; padding: 0.15rem 0.4rem;">{tag}</span>
          ))}
        </div>
      )}
      <h1 style="font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 700; letter-spacing: -0.04em; color: #fff; margin: 0 0 1rem; line-height: 1.2;">{post.data.title}</h1>
      <p style="font-size: 1.0625rem; color: var(--text-muted); line-height: 1.65; margin: 0 0 1.5rem;">{post.data.description}</p>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <time datetime={post.data.pubDate.toISOString()} style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--text-subtle);">
          {post.data.pubDate.toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span style="color: var(--border);">·</span>
        <span style="font-size: 0.8rem; color: var(--text-subtle);">Tristan de Kock</span>
      </div>
    </header>

    <hr style="border: none; border-top: 1px solid var(--border); margin-bottom: 3rem;" />

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>

    <!-- Footer -->
    <hr style="border: none; border-top: 1px solid var(--border); margin-top: 4rem; margin-bottom: 2rem;" />
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <a href="/writing" style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--text-muted);">
        &larr; All writing
      </a>
      <a href="https://www.linkedin.com/in/tristandekock" target="_blank" rel="noopener" style="font-size: 0.8rem; color: var(--accent);">
        Follow on LinkedIn
      </a>
    </div>

  </article>
</Layout>
