---
import Layout from '../../layouts/Layout.astro';
import { products, getProduct } from '../../data/products';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const p = product;
const isCustodian = p.slug === 'custodian';
const isSentinel = p.slug === 'sentinel';
---

<Layout
  title={`${p.name} — Custos`}
  description={`${p.tagline}. ${p.detail.summary.slice(0, 110)}`}
>
  <article class="wrap-narrow" style="padding: 4rem 1.5rem 0;">

    <a href="/products" style="font-size: 0.85rem; color: var(--text-muted); display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 2.5rem;">
      &larr; All products
    </a>

    <!-- Header -->
    <header>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; margin-bottom: 1.5rem;">
        <span class="chip">{p.reg}</span>
        <span class="status-badge">In development</span>
      </div>
      <h1 class="h-display" style="font-size: clamp(2.25rem, 6vw, 3.5rem); margin: 0;">{p.name}</h1>
      <p class="lead" style="margin: 1.25rem 0 0; max-width: 52ch;">{p.tagline}</p>
    </header>

    <p style="margin: 2.5rem 0 0; font-size: 1.05rem; color: var(--text); line-height: 1.7; max-width: 64ch;">{p.detail.summary}</p>
  </article>

  {isSentinel && (
    <!-- INTERACTIVE CLAIMS-TRIAGE DEMO -->
    <section class="wrap-narrow" style="padding: 3rem 1.5rem 0;">
      <div class="rule"><span class="sec-num">[ DEMO ]</span><h2 class="label" style="margin: 0;">See Sentinel triage a claim</h2></div>
      <p style="margin: 0 0 1.75rem; font-size: 0.95rem; color: var(--text-muted); line-height: 1.65; max-width: 60ch;">
        A sample pre-authorisation request, processed the way Sentinel would: read, PII tagged, drafted, and flagged. Nothing leaves South Africa. This is an illustration of the workflow, not live member data.
      </p>

      <div class="demo demo-sentinel">
        <div class="demo-grid">
          <!-- Input document -->
          <div class="demo-doc">
            <div class="demo-doc-head">
              <span class="demo-doc-type">Pre-authorisation request</span>
              <span class="demo-doc-id">REF PA-20418</span>
            </div>
            <div class="demo-doc-body">
              <p><span class="pii" data-pii>Thandiwe Mokoena</span>, member <span class="pii" data-pii>884 221 905</span>, requests pre-authorisation for an <strong>MRI lumbar spine</strong> following <span class="pii" data-pii>chronic lower-back pain</span> over 6 weeks. Referring provider: <span class="pii" data-pii>Dr S. Naidoo (PR 0294817)</span>. Plan: Comprehensive. Tariff code <strong>3014</strong>.</p>
            </div>
            <div class="demo-doc-foot">
              <span class="sa-stamp"><span class="sa-dot"></span> Stays in SA</span>
            </div>
          </div>

          <!-- Output -->
          <div class="demo-out">
            <ol class="demo-steps" id="sentinel-steps">
              <li class="demo-step" data-step="0">
                <span class="step-tick"></span>
                <div><span class="step-title">Document read</span><span class="step-detail">Pre-auth request parsed and classified</span></div>
              </li>
              <li class="demo-step" data-step="1">
                <span class="step-tick"></span>
                <div><span class="step-title">PII tagged</span><span class="step-detail"><span id="pii-count">4</span> items of special personal information identified and protected</span></div>
              </li>
              <li class="demo-step" data-step="2">
                <span class="step-tick"></span>
                <div><span class="step-title">PMB &amp; coding checked</span><span class="step-detail">Tariff 3014 valid · imaging requires clinical motivation</span></div>
              </li>
              <li class="demo-step" data-step="3">
                <span class="step-tick"></span>
                <div><span class="step-title">Response drafted</span><span class="step-detail">Ready for a human reviewer to approve</span></div>
              </li>
            </ol>

            <div class="demo-draft" id="sentinel-draft" hidden>
              <p class="demo-draft-label">Drafted response</p>
              <p class="demo-draft-body">Pre-authorisation <strong>conditionally approved</strong> for MRI lumbar spine (tariff 3014). Conservative-treatment history of 6 weeks meets the imaging motivation threshold. Flag: confirm no MRI in prior 12 months before final sign-off.</p>
              <p class="demo-flag"><span class="flag-dot"></span> 1 item routed for human review</p>
            </div>
          </div>
        </div>

        <div class="demo-bar">
          <button class="demo-run btn-cta" id="sentinel-run" type="button">Process with Sentinel</button>
          <span class="demo-audit" id="sentinel-audit">Every step logged for the CMS audit trail.</span>
        </div>
      </div>
    </section>
  )}

  {isCustodian && (
    <!-- INTERACTIVE DATA-FLOW EXPLORER -->
    <section class="wrap-narrow" style="padding: 3rem 1.5rem 0;">
      <div class="rule"><span class="sec-num">[ LIVE ]</span><h2 class="label" style="margin: 0;">Where does personal data actually go?</h2></div>
      <p style="margin: 0 0 1.75rem; font-size: 0.95rem; color: var(--text-muted); line-height: 1.65; max-width: 60ch;">
        Click each layer of an AI workload to see what personal information passes through it, and where the sovereignty boundary really sits. This is what Custodian maps, continuously.
      </p>

      <div class="explorer">
        <div class="explorer-track" role="list">
          <button class="layer" data-i="0" role="listitem" aria-pressed="false">
            <span class="layer-dot"></span><span class="layer-name">Storage</span>
          </button>
          <span class="layer-link"></span>
          <button class="layer" data-i="1" role="listitem" aria-pressed="false">
            <span class="layer-dot"></span><span class="layer-name">Embeddings</span>
          </button>
          <span class="layer-link"></span>
          <button class="layer" data-i="2" role="listitem" aria-pressed="false">
            <span class="layer-dot"></span><span class="layer-name">Prompt history</span>
          </button>
          <span class="layer-link"></span>
          <button class="layer boundary" data-i="3" role="listitem" aria-pressed="false">
            <span class="layer-dot"></span><span class="layer-name">Inference</span>
          </button>
        </div>

        <div class="explorer-readout" id="readout" aria-live="polite">
          <p class="readout-label">Select a layer</p>
          <p class="readout-body">Most teams have mapped storage and stopped there. Personal information keeps moving long after it leaves the database. Tap a layer above.</p>
        </div>
      </div>
    </section>
  )}

  <!-- Why it exists -->
  <section class="wrap-narrow" style="padding: 3rem 1.5rem 0;">
    <div class="rule"><span class="sec-num">[ WHY ]</span><h2 class="label" style="margin: 0;">Why it exists</h2></div>
    <p style="margin: 0; font-size: 1rem; color: var(--text-muted); line-height: 1.75; max-width: 64ch;">{p.detail.why}</p>
  </section>

  <!-- How it works -->
  <section class="wrap-narrow" style="padding: 3rem 1.5rem 0;">
    <div class="rule"><span class="sec-num">[ HOW ]</span><h2 class="label" style="margin: 0;">How it works</h2></div>
    <div class="arch-grid">
      {p.detail.architecture.map((step, i) => (
        <div class="arch-step">
          <span class="spec-num">{String(i + 1).padStart(2, '0')}</span>
          <h3 style="font-size: 1rem; font-weight: 600; color: #fff; margin: 0.5rem 0 0.4rem;">{step.label}</h3>
          <p style="margin: 0; font-size: 0.88rem; color: var(--text-muted); line-height: 1.6;">{step.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Regulatory frame + who it's for -->
  <section class="wrap-narrow" style="padding: 3rem 1.5rem 0;">
    <div class="grid-about" style="gap: 2.5rem;">
      <div>
        <p class="label" style="margin: 0 0 0.9rem;">Regulatory frame</p>
        <ul style="margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.6rem;">
          {p.detail.regulatory.map((r) => (
            <li style="display: flex; gap: 0.7rem; font-size: 0.92rem; color: var(--text); line-height: 1.5;">
              <span style="color: var(--accent); font-family: 'JetBrains Mono', monospace; flex-shrink: 0;">&sect;</span>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
      <aside>
        <div class="card">
          <p class="label" style="margin: 0 0 0.75rem;">Who it's for</p>
          <p style="margin: 0 0 1.25rem; font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;">{p.for}</p>
          <p class="label" style="margin: 0 0 0.5rem;">Status</p>
          <p style="margin: 0; font-size: 0.88rem; color: var(--brass); line-height: 1.55;">{p.detail.status}</p>
        </div>
      </aside>
    </div>
  </section>

  <!-- CTA -->
  <section class="wrap-narrow" style="padding: 3rem 1.5rem 0;">
    <div style="border: 1px solid var(--accent-border); border-radius: 12px; background: linear-gradient(135deg, rgba(59,130,246,0.06), transparent 60%), var(--bg-surface); padding: 2.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.5rem;">
      <div>
        <h2 class="h-section" style="font-size: 1.5rem; margin: 0 0 0.5rem;">Wrestling with this now?</h2>
        <p style="margin: 0; font-size: 0.95rem; color: var(--text-muted); max-width: 48ch; line-height: 1.6;">{p.name} is being built with design partners. If this is your problem, help shape it.</p>
      </div>
      <a href="/contact" class="btn-cta">Become a design partner</a>
    </div>
  </section>

  <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; padding: 2.5rem 1.5rem 0; max-width: 760px; margin: 0 auto;">
    {products.filter((o) => o.slug !== p.slug).map((o) => (
      <a href={`/products/${o.slug}`} style="font-size: 0.85rem; color: var(--text-muted);">{o.name} &rarr;</a>
    ))}
  </div>
</Layout>

<style>
  .status-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
    color: var(--brass); background: var(--brass-dim);
    border: 1px solid var(--brass-border); border-radius: 999px;
    padding: 0.25rem 0.65rem; white-space: nowrap;
  }
  .status-badge::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--brass); box-shadow: 0 0 8px var(--brass);
  }
  .arch-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  .arch-step {
    border: 1px solid var(--border); border-radius: 10px;
    background: var(--bg-surface); padding: 1.4rem 1.25rem;
  }

  /* ---- Sentinel claims-triage demo ---- */
  .demo {
    border: 1px solid var(--border); border-radius: 14px;
    background: linear-gradient(180deg, var(--bg-surface), var(--bg));
    padding: 1.75rem; box-shadow: 0 24px 60px -34px rgba(0,0,0,0.8);
  }
  .demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

  .demo-doc, .demo-out {
    border: 1px solid var(--border); border-radius: 10px;
    background: var(--bg); display: flex; flex-direction: column;
  }
  .demo-doc-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.85rem 1.1rem; border-bottom: 1px solid var(--border);
  }
  .demo-doc-type { font-size: 0.8rem; font-weight: 600; color: #fff; }
  .demo-doc-id { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--text-subtle); }
  .demo-doc-body { padding: 1.1rem; flex: 1; }
  .demo-doc-body p { margin: 0; font-size: 0.88rem; line-height: 1.65; color: var(--text-muted); }
  .demo-doc-body strong { color: var(--text); font-weight: 600; }
  .pii {
    border-radius: 3px; padding: 0 2px; transition: background 0.4s ease, color 0.4s ease, box-shadow 0.4s ease;
  }
  .pii.tagged {
    background: var(--accent-dim); color: var(--accent-bright);
    box-shadow: inset 0 0 0 1px var(--accent-border-soft);
  }
  .demo-doc-foot { padding: 0.75rem 1.1rem; border-top: 1px solid var(--border); }
  .sa-stamp {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
    color: var(--brass);
  }
  .sa-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--brass); box-shadow: 0 0 8px var(--brass); }

  .demo-out { padding: 1.1rem; }
  .demo-steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.9rem; }
  .demo-step { display: flex; gap: 0.75rem; align-items: flex-start; opacity: 0.3; transition: opacity 0.4s ease; }
  .demo-step.done { opacity: 1; }
  .step-tick {
    width: 18px; height: 18px; border-radius: 50%; flex-shrink: 0; margin-top: 1px;
    border: 2px solid var(--border); background: var(--bg);
    transition: border-color 0.3s, background 0.3s; position: relative;
  }
  .demo-step.done .step-tick { border-color: var(--accent); background: var(--accent); }
  .demo-step.done .step-tick::after {
    content: ""; position: absolute; left: 4px; top: 1px;
    width: 4px; height: 8px; border: solid #04122e; border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .step-title { display: block; font-size: 0.85rem; font-weight: 600; color: #fff; }
  .step-detail { display: block; font-size: 0.78rem; color: var(--text-muted); line-height: 1.45; margin-top: 0.1rem; }

  .demo-draft {
    margin-top: 1.1rem; padding-top: 1.1rem; border-top: 1px dashed var(--border);
    animation: demo-fade 0.5s ease;
  }
  .demo-draft-label {
    font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--accent); margin: 0 0 0.5rem;
  }
  .demo-draft-body { margin: 0; font-size: 0.84rem; color: var(--text); line-height: 1.6; }
  .demo-draft-body strong { color: var(--accent-bright); }
  .demo-flag {
    display: flex; align-items: center; gap: 0.4rem; margin: 0.85rem 0 0;
    font-size: 0.78rem; color: var(--brass);
  }
  .flag-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--brass); }
  @keyframes demo-fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  .demo-bar {
    display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .demo-run { border: none; cursor: pointer; }
  .demo-run:disabled { opacity: 0.6; cursor: default; }
  .demo-audit { font-family: 'JetBrains Mono', monospace; font-size: 0.74rem; color: var(--text-subtle); }

  /* ---- Interactive data-flow explorer ---- */
  .explorer {
    border: 1px solid var(--border); border-radius: 14px;
    background: linear-gradient(180deg, var(--bg-surface), var(--bg));
    padding: 2rem 1.75rem; box-shadow: 0 24px 60px -34px rgba(0,0,0,0.8);
  }
  .explorer-track {
    display: flex; align-items: center; gap: 0; flex-wrap: wrap;
    justify-content: space-between; margin-bottom: 1.75rem;
  }
  .layer {
    display: flex; flex-direction: column; align-items: center; gap: 0.55rem;
    background: transparent; border: none; cursor: pointer; padding: 0.25rem;
    font-family: inherit; color: var(--text-muted); transition: color 0.18s;
    flex: 0 0 auto;
  }
  .layer-dot {
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--bg); border: 2px solid var(--border);
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .layer-name { font-size: 0.82rem; font-weight: 600; white-space: nowrap; }
  .layer-link { flex: 1 1 auto; height: 2px; background: var(--border); min-width: 18px; }
  .layer:hover { color: var(--text); }
  .layer:hover .layer-dot { border-color: var(--accent); }
  .layer[aria-pressed="true"] { color: #fff; }
  .layer[aria-pressed="true"] .layer-dot {
    border-color: var(--accent); background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-dim);
  }
  .layer.boundary[aria-pressed="true"] .layer-dot {
    border-color: var(--brass); background: var(--brass);
    box-shadow: 0 0 0 4px var(--brass-dim);
  }
  .explorer-readout {
    border-top: 1px solid var(--border); padding-top: 1.5rem; min-height: 96px;
  }
  .readout-label {
    font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent);
    margin: 0 0 0.6rem;
  }
  .readout-label.boundary { color: var(--brass); }
  .readout-body { margin: 0; font-size: 0.95rem; color: var(--text); line-height: 1.65; }

  @media (max-width: 720px) {
    .arch-grid { grid-template-columns: 1fr 1fr; }
    .explorer-track { gap: 0.5rem; }
    .layer-link { display: none; }
    .layer { flex: 1 1 40%; }
    .demo-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .arch-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const layers = [
    { label: 'Storage', boundary: false, body: 'Member and customer records sit in a database. This is the layer everyone maps. POPIA residency rules are usually satisfied here, so teams assume the job is done.' },
    { label: 'Embeddings', boundary: false, body: 'To make data searchable by an AI, it is turned into vectors and stored in a vector database. These embeddings still encode personal information, and they are often hosted somewhere different from the source data.' },
    { label: 'Prompt history', boundary: false, body: 'Every question and retrieved chunk is assembled into a prompt, and prompts are frequently logged for debugging and evaluation. That log is a fresh copy of personal information, often overlooked entirely.' },
    { label: 'Inference', boundary: true, body: 'The prompt is sent to the model. If that model runs on a US-controlled provider, personal information has now crossed a jurisdictional boundary, regardless of where the disk sits. This is where residency ends and sovereignty begins.' },
  ];

  const buttons = Array.from(document.querySelectorAll('.layer'));
  const readout = document.getElementById('readout');
  if (buttons.length && readout) {
    const labelEl = readout.querySelector('.readout-label');
    const bodyEl = readout.querySelector('.readout-body');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const i = Number(btn.getAttribute('data-i'));
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        const layer = layers[i];
        labelEl.textContent = layer.boundary ? 'Sovereignty boundary' : layer.label;
        labelEl.classList.toggle('boundary', layer.boundary);
        bodyEl.textContent = layer.body;
      });
    });
  }

  // --- Sentinel claims-triage demo ---
  const runBtn = document.getElementById('sentinel-run');
  if (runBtn) {
    const steps = Array.from(document.querySelectorAll('#sentinel-steps .demo-step'));
    const piiEls = Array.from(document.querySelectorAll('.demo-sentinel [data-pii]'));
    const draft = document.getElementById('sentinel-draft');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const reset = () => {
      steps.forEach((s) => s.classList.remove('done'));
      piiEls.forEach((e) => e.classList.remove('tagged'));
      if (draft) draft.hidden = true;
    };

    const wait = (ms) => new Promise((r) => setTimeout(r, reduce ? 0 : ms));

    runBtn.addEventListener('click', async () => {
      reset();
      runBtn.disabled = true;
      runBtn.textContent = 'Processing…';

      await wait(450);
      steps[0].classList.add('done');           // read
      await wait(650);
      steps[1].classList.add('done');           // pii tagged
      piiEls.forEach((e, i) => setTimeout(() => e.classList.add('tagged'), reduce ? 0 : i * 160));
      await wait(900);
      steps[2].classList.add('done');           // pmb checked
      await wait(700);
      steps[3].classList.add('done');           // drafted
      await wait(350);
      if (draft) draft.hidden = false;

      runBtn.textContent = 'Run again';
      runBtn.disabled = false;
    });
  }
</script>
