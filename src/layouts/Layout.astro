---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Pass for blog posts: marks the page as an article with author + date. */
  article?: { publishedTime?: string; author?: string; tags?: string[] };
}

const {
  title,
  description = 'Sovereign AI architecture for SA regulated industries. POPIA-compliant AI deployments for medical aid, banking, and insurance.',
  ogImage = '/og-default.png',
  article,
} = Astro.props;

const ogType = article ? 'article' : 'website';
const articleAuthor = article?.author ?? 'Custos';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;

const nav = [
  { href: '/approach', label: 'Approach' },
  { href: '/services', label: 'Services' },
  { href: '/writing', label: 'Writing' },
  { href: '/about', label: 'About' },
];

const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

// Structured data: tells search engines who Custos is and that this is the
// canonical site. Helps own branded + niche-term searches.
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://custosza.com';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'Custos',
      url: siteUrl,
      logo: `${siteUrl}/logo-mark.svg`,
      description:
        'Sovereign, POPIA-compliant AI architecture for South African regulated industries: medical aid, banking, and insurance.',
      areaServed: { '@type': 'Country', name: 'South Africa' },
      knowsAbout: [
        'Sovereign AI',
        'POPIA compliance',
        'AI data residency',
        'LLM architecture',
        'Regulated industry AI',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'Custos',
      publisher: { '@id': `${siteUrl}/#organization` },
      inLanguage: 'en-ZA',
    },
    // For blog posts, add an Article node so Google shows date.
    ...(article
      ? [{
          '@type': 'Article',
          headline: title,
          description,
          author: { '@id': `${siteUrl}/#organization` },
          publisher: { '@id': `${siteUrl}/#organization` },
          ...(article.publishedTime ? { datePublished: article.publishedTime } : {}),
          mainEntityOfPage: canonicalURL.toString(),
          inLanguage: 'en-ZA',
        }]
      : []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content={ogType} />
    {article && (
      <>
        <meta property="article:author" content={articleAuthor} />
        {article.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
        {article.tags?.map((t) => <meta property="article:tag" content={t} />)}
      </>
    )}
    <meta property="og:site_name" content="Custos" />
    <meta property="og:locale" content="en_ZA" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Custos — sovereign AI architecture for SA regulated industries" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="alternate" type="application/rss+xml" title="Custos" href="/rss.xml" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body style="background: var(--bg);">
    <header style="border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px); background: rgba(11,14,13,0.82);">
      <div class="wrap nav-grid" style="height: 60px;">
        <a href="/" class="nav-brand" style="color: #fff; font-weight: 700; font-size: 1.0625rem; letter-spacing: -0.02em; display: flex; align-items: center; gap: 0.6rem;">
          <img src="/logo-mark.svg" width="28" height="28" alt="" style="flex-shrink: 0; display: block;" />
          <span>Custos<span style="color: var(--text-subtle); font-weight: 500;">.za</span></span>
        </a>
        <nav class="nav-links">
          {nav.map((item) => (
            <a
              href={item.href}
              style={`font-size: 0.875rem; transition: color 0.15s; color: ${isActive(item.href) ? '#fff' : 'var(--text-muted)'};`}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <a href="/contact" class="nav-cta" style="justify-self: end;">Get in touch</a>

        <!-- Mobile hamburger toggle -->
        <button id="menu-toggle" class="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="menu-bar"></span>
          <span class="menu-bar"></span>
          <span class="menu-bar"></span>
        </button>
      </div>

      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="mobile-menu" hidden>
        <nav class="mobile-menu-inner">
          {nav.map((item) => (
            <a
              href={item.href}
              class="mobile-menu-link"
              style={`color: ${isActive(item.href) ? '#fff' : 'var(--text-muted)'};`}
            >
              {item.label}
            </a>
          ))}
          <a href="/contact" class="mobile-menu-link" style="color: var(--brass);">Get in touch &rarr;</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer style="border-top: 1px solid var(--border); margin-top: 7rem;">
      <div class="wrap" style="padding-top: 3rem; padding-bottom: 3rem;">
        <div class="grid-footer" style="margin-bottom: 2.5rem;">
          <div>
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
              <img src="/logo-mark.svg" width="22" height="22" alt="" style="display: block;" />
              <span style="color: #fff; font-weight: 700;">Custos<span style="color: var(--text-subtle); font-weight: 500;">.za</span></span>
            </div>
            <p style="margin: 0; font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; max-width: 32ch;">
              Sovereign AI architecture for South African regulated industries.
            </p>
          </div>
          <div>
            <p class="label" style="margin: 0 0 0.9rem;">Site</p>
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <a href="/approach" style="font-size: 0.85rem; color: var(--text-muted);">Approach</a>
              <a href="/services" style="font-size: 0.85rem; color: var(--text-muted);">Services</a>
              <a href="/writing" style="font-size: 0.85rem; color: var(--text-muted);">Writing</a>
              <a href="/about" style="font-size: 0.85rem; color: var(--text-muted);">About</a>
            </div>
          </div>
          <div>
            <p class="label" style="margin: 0 0 0.9rem;">Connect</p>
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <a href="/contact" style="font-size: 0.85rem; color: var(--text-muted);">Get in touch</a>
              <a href="mailto:hello@custosza.com" style="font-size: 0.85rem; color: var(--text-muted);">hello@custosza.com</a>
              <a href="/rss.xml" style="font-size: 0.85rem; color: var(--text-muted);">RSS</a>
            </div>
          </div>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; border-top: 1px solid var(--border); padding-top: 1.5rem;">
          <p style="margin: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-subtle);">
            Cape Town, South Africa · SAST (UTC+2)
          </p>
          <p style="margin: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-subtle);">
            © 2026 Custos
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Site-wide scroll reveal + magnetic micro-interactions (modern-web-design skill)
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      const fine = window.matchMedia('(pointer: fine)').matches;
      const noReduce = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (fine && noReduce) {
        document.querySelectorAll('[data-magnetic]').forEach((el) => {
          el.style.transition = 'transform .25s cubic-bezier(.2,.7,.2,1)';
          el.addEventListener('mousemove', (e) => {
            const r = el.getBoundingClientRect();
            const dx = e.clientX - (r.left + r.width / 2);
            const dy = e.clientY - (r.top + r.height / 2);
            el.style.transform = `translate(${dx * 0.25}px, ${dy * 0.35}px)`;
          });
          el.addEventListener('mouseleave', () => { el.style.transform = 'translate(0,0)'; });
        });
      }

      // Mobile menu toggle
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      if (toggle && menu) {
        const setOpen = (open) => {
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
          menu.hidden = !open;
        };
        toggle.addEventListener('click', () => {
          setOpen(toggle.getAttribute('aria-expanded') !== 'true');
        });
        // Close when a menu link is tapped
        menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
        // Close on Escape
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
        // Reset when resizing up to desktop
        window.matchMedia('(min-width: 721px)').addEventListener('change', (e) => { if (e.matches) setOpen(false); });
      }
    </script>
  </body>
</html>
