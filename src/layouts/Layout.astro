---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Sovereign AI architecture for SA regulated industries. POPIA-compliant AI deployments for medical aid, banking, and insurance.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;

const nav = [
  { href: '/approach', label: 'Approach' },
  { href: '/services', label: 'Services' },
  { href: '/writing', label: 'Writing' },
  { href: '/about', label: 'About' },
];

const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="alternate" type="application/rss+xml" title="Custos" href="/rss.xml" />
  </head>
  <body style="background: var(--bg);">
    <header style="border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px); background: rgba(11,14,13,0.82);">
      <div class="wrap" style="display: flex; align-items: center; justify-content: space-between; height: 60px;">
        <a href="/" style="color: #fff; font-weight: 700; font-size: 1.0625rem; letter-spacing: -0.02em; display: flex; align-items: center; gap: 0.6rem;">
          <img src="/logo-mark.svg" width="28" height="28" alt="" style="flex-shrink: 0; display: block;" />
          Custos<span style="color: var(--text-subtle); font-weight: 500;">.za</span>
        </a>
        <nav class="nav-links">
          {nav.map((item) => (
            <a
              href={item.href}
              style={`font-size: 0.875rem; transition: color 0.15s; color: ${isActive(item.href) ? '#fff' : 'var(--text-muted)'};`}
            >
              {item.label}
            </a>
          ))}
          <a href="/contact" class="nav-cta" style="font-size: 0.8125rem; color: var(--brass); border: 1px solid var(--brass-border); padding: 0.4rem 0.85rem; border-radius: 5px; font-family: 'JetBrains Mono', monospace; transition: all 0.15s;">
            Get in touch
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer style="border-top: 1px solid var(--border); margin-top: 7rem;">
      <div class="wrap" style="padding-top: 3rem; padding-bottom: 3rem;">
        <div class="grid-footer" style="margin-bottom: 2.5rem;">
          <div>
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
              <img src="/logo-mark.svg" width="22" height="22" alt="" style="display: block;" />
              <span style="color: #fff; font-weight: 700;">Custos<span style="color: var(--text-subtle); font-weight: 500;">.za</span></span>
            </div>
            <p style="margin: 0; font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; max-width: 32ch;">
              Sovereign AI architecture for South African regulated industries.
            </p>
          </div>
          <div>
            <p class="label" style="margin: 0 0 0.9rem;">Site</p>
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <a href="/approach" style="font-size: 0.85rem; color: var(--text-muted);">Approach</a>
              <a href="/services" style="font-size: 0.85rem; color: var(--text-muted);">Services</a>
              <a href="/writing" style="font-size: 0.85rem; color: var(--text-muted);">Writing</a>
              <a href="/about" style="font-size: 0.85rem; color: var(--text-muted);">About</a>
            </div>
          </div>
          <div>
            <p class="label" style="margin: 0 0 0.9rem;">Connect</p>
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <a href="https://www.linkedin.com/in/tristandekock" target="_blank" rel="noopener" style="font-size: 0.85rem; color: var(--text-muted);">LinkedIn</a>
              <a href="/contact" style="font-size: 0.85rem; color: var(--text-muted);">Get in touch</a>
              <a href="/rss.xml" style="font-size: 0.85rem; color: var(--text-muted);">RSS</a>
            </div>
          </div>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; border-top: 1px solid var(--border); padding-top: 1.5rem;">
          <p style="margin: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-subtle);">
            Cape Town, South Africa · SAST (UTC+2)
          </p>
          <p style="margin: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-subtle);">
            © 2026 Custos
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Site-wide scroll reveal + magnetic micro-interactions (modern-web-design skill)
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      const fine = window.matchMedia('(pointer: fine)').matches;
      const noReduce = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (fine && noReduce) {
        document.querySelectorAll('[data-magnetic]').forEach((el) => {
          el.style.transition = 'transform .25s cubic-bezier(.2,.7,.2,1)';
          el.addEventListener('mousemove', (e) => {
            const r = el.getBoundingClientRect();
            const dx = e.clientX - (r.left + r.width / 2);
            const dy = e.clientY - (r.top + r.height / 2);
            el.style.transform = `translate(${dx * 0.25}px, ${dy * 0.35}px)`;
          });
          el.addEventListener('mouseleave', () => { el.style.transform = 'translate(0,0)'; });
        });
      }
    </script>
  </body>
</html>
