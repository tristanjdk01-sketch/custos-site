# Copy this file to seo/.env and fill in the values.
# seo/.env is gitignored. Never commit it. Never paste these values into chat.

# The site to audit. Defaults to production if omitted.
SITE_URL=https://custosza.com

# --- Optional: only needed for higher PSI rate limits and for GSC scripts ---

# Google Cloud project that owns the service account.
GCP_PROJECT_ID=

# Relative path (from seo/) to the service-account JSON key you downloaded.
# Keep it in seo/.secrets/ (gitignored). Treat it like a password.
GCP_SA_KEY_PATH=.secrets/gcp-seo-sa.json

# PageSpeed Insights API key (optional). Generate via:
#   node scripts/create-api-key.mjs
PSI_API_KEY=
